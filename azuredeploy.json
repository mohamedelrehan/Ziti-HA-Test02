{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "ha-test02.2.0",
  "parameters": {
    "deploymentPrefix": {
      "type": "string",
      "defaultValue": "ziti-ha021"
    },
    "adminUsername": {
      "type": "string",
      "defaultValue": "azureuser"
    },
    "adminPassword": {
      "type": "secureString"
    },
    "controllerVmSize": {
      "type": "string",
      "defaultValue": "Standard_B2s"
    },
    "routerVmSize": {
      "type": "string",
      "defaultValue": "Standard_B2s"
    },
    "dnsLabelPrefix": {
      "type": "string"
    },
    "adminSourceAddressPrefix": {
      "type": "string",
      "defaultValue": "*"
    },
    "zitiAdminUser": {
      "type": "string",
      "defaultValue": "admin"
    },
    "zitiAdminPassword": {
      "type": "secureString"
    },
    "runAptUpgrade": {
      "type": "string",
      "defaultValue": "true",
      "allowedValues": [
        "true",
        "false"
      ]
    },
    "repoRawBaseUrl": {
      "type": "string",
      "defaultValue": "https://raw.githubusercontent.com/mohamedelrehan/Ziti-HA-Test02/main"
    },
    "vnetName": {
      "type": "string",
      "defaultValue": "ziti-ha021-vnet"
    },
    "vnetAddressPrefix": {
      "type": "string",
      "defaultValue": "10.97.0.0/16"
    },
    "infraSubnetName": {
      "type": "string",
      "defaultValue": "ziti-ha-infra-subnet"
    },
    "infraSubnetPrefix": {
      "type": "string",
      "defaultValue": "10.97.1.0/24"
    },
    "routerSubnetName": {
      "type": "string",
      "defaultValue": "ziti-ha-router-subnet"
    },
    "routerSubnetPrefix": {
      "type": "string",
      "defaultValue": "10.97.2.0/24"
    },
    "controller01Zone": {
      "type": "string",
      "defaultValue": "1",
      "allowedValues": [
        "1",
        "2",
        "3"
      ]
    },
    "controller02Zone": {
      "type": "string",
      "defaultValue": "2",
      "allowedValues": [
        "1",
        "2",
        "3"
      ]
    },
    "controller03Zone": {
      "type": "string",
      "defaultValue": "3",
      "allowedValues": [
        "1",
        "2",
        "3"
      ]
    },
    "router01Zone": {
      "type": "string",
      "defaultValue": "1",
      "allowedValues": [
        "1",
        "2",
        "3"
      ]
    },
    "router02Zone": {
      "type": "string",
      "defaultValue": "2",
      "allowedValues": [
        "1",
        "2",
        "3"
      ]
    },
    "router03Zone": {
      "type": "string",
      "defaultValue": "3",
      "allowedValues": [
        "1",
        "2",
        "3"
      ]
    }
  },
  "variables": {
    "controllerScriptUrl": "[concat(parameters('repoRawBaseUrl'), '/scripts/azure-bootstrap-ziti-ha-controller-primary-v4.sh')]",
    "routerScriptUrl": "[concat(parameters('repoRawBaseUrl'), '/scripts/azure-bootstrap-ziti-ha-router-v4.sh')]",
    "infraNsgName": "[concat(parameters('deploymentPrefix'), '-infra-nsg')]",
    "routerNsgName": "[concat(parameters('deploymentPrefix'), '-router-nsg')]",
    "routerRouteTableName": "[concat(parameters('deploymentPrefix'), '-router-rt')]",
    "controller01VmName": "[concat(parameters('deploymentPrefix'), '-controller01')]",
    "controller01Fqdn": "[concat(parameters('dnsLabelPrefix'), '-c01.', resourceGroup().location, '.cloudapp.azure.com')]",
    "controller01PrivateIp": "[concat('10.97.1.', string(add(3, 1)))]",
    "controller02VmName": "[concat(parameters('deploymentPrefix'), '-controller02')]",
    "controller02Fqdn": "[concat(parameters('dnsLabelPrefix'), '-c02.', resourceGroup().location, '.cloudapp.azure.com')]",
    "controller02PrivateIp": "[concat('10.97.1.', string(add(3, 2)))]",
    "controller03VmName": "[concat(parameters('deploymentPrefix'), '-controller03')]",
    "controller03Fqdn": "[concat(parameters('dnsLabelPrefix'), '-c03.', resourceGroup().location, '.cloudapp.azure.com')]",
    "controller03PrivateIp": "[concat('10.97.1.', string(add(3, 3)))]",
    "router01VmName": "[concat(parameters('deploymentPrefix'), '-router01')]",
    "router01Fqdn": "[concat(parameters('dnsLabelPrefix'), '-r01.', resourceGroup().location, '.cloudapp.azure.com')]",
    "router01PrivateIp": "[concat('10.97.2.', string(add(3, 1)))]",
    "router02VmName": "[concat(parameters('deploymentPrefix'), '-router02')]",
    "router02Fqdn": "[concat(parameters('dnsLabelPrefix'), '-r02.', resourceGroup().location, '.cloudapp.azure.com')]",
    "router02PrivateIp": "[concat('10.97.2.', string(add(3, 2)))]",
    "router03VmName": "[concat(parameters('deploymentPrefix'), '-router03')]",
    "router03Fqdn": "[concat(parameters('dnsLabelPrefix'), '-r03.', resourceGroup().location, '.cloudapp.azure.com')]",
    "router03PrivateIp": "[concat('10.97.2.', string(add(3, 3)))]",
    "controllerPrimaryScriptUrl": "[concat(parameters('repoRawBaseUrl'), '/scripts/azure-bootstrap-ziti-ha-controller-primary-v4.sh')]",
    "controllerSecondaryScriptUrl": "[concat(parameters('repoRawBaseUrl'), '/scripts/azure-bootstrap-ziti-ha-controller-secondary-v4.sh')]"
  },
  "resources": [
    {
      "type": "Microsoft.Network/networkSecurityGroups",
      "apiVersion": "2023-11-01",
      "name": "[variables('infraNsgName')]",
      "location": "[resourceGroup().location]",
      "properties": {
        "securityRules": [
          {
            "name": "Allow-SSH-Admin",
            "properties": {
              "priority": 100,
              "direction": "Inbound",
              "access": "Allow",
              "protocol": "Tcp",
              "sourcePortRange": "*",
              "destinationPortRange": "22",
              "sourceAddressPrefix": "[parameters('adminSourceAddressPrefix')]",
              "destinationAddressPrefix": "*"
            }
          },
          {
            "name": "Allow-Controller-1280-Internet-Test",
            "properties": {
              "priority": 110,
              "direction": "Inbound",
              "access": "Allow",
              "protocol": "Tcp",
              "sourcePortRange": "*",
              "destinationPortRange": "1280",
              "sourceAddressPrefix": "Internet",
              "destinationAddressPrefix": "*"
            }
          },
          {
            "name": "Allow-Controller-6262-Infra",
            "properties": {
              "priority": 120,
              "direction": "Inbound",
              "access": "Allow",
              "protocol": "Tcp",
              "sourcePortRange": "*",
              "destinationPortRange": "6262",
              "sourceAddressPrefix": "[parameters('infraSubnetPrefix')]",
              "destinationAddressPrefix": "*"
            }
          },
          {
            "name": "Allow-HTTP",
            "properties": {
              "priority": 130,
              "direction": "Inbound",
              "access": "Allow",
              "protocol": "Tcp",
              "sourcePortRange": "*",
              "destinationPortRange": "80",
              "sourceAddressPrefix": "Internet",
              "destinationAddressPrefix": "*"
            }
          },
          {
            "name": "Allow-HTTPS",
            "properties": {
              "priority": 140,
              "direction": "Inbound",
              "access": "Allow",
              "protocol": "Tcp",
              "sourcePortRange": "*",
              "destinationPortRange": "443",
              "sourceAddressPrefix": "Internet",
              "destinationAddressPrefix": "*"
            }
          }
        ]
      }
    },
    {
      "type": "Microsoft.Network/networkSecurityGroups",
      "apiVersion": "2023-11-01",
      "name": "[variables('routerNsgName')]",
      "location": "[resourceGroup().location]",
      "properties": {
        "securityRules": [
          {
            "name": "Allow-SSH-Admin",
            "properties": {
              "priority": 100,
              "direction": "Inbound",
              "access": "Allow",
              "protocol": "Tcp",
              "sourcePortRange": "*",
              "destinationPortRange": "22",
              "sourceAddressPrefix": "[parameters('adminSourceAddressPrefix')]",
              "destinationAddressPrefix": "*"
            }
          },
          {
            "name": "Allow-Router-Link-3022",
            "properties": {
              "priority": 120,
              "direction": "Inbound",
              "access": "Allow",
              "protocol": "Tcp",
              "sourcePortRange": "*",
              "destinationPortRange": "3022",
              "sourceAddressPrefix": "Internet",
              "destinationAddressPrefix": "*"
            }
          },
          {
            "name": "Allow-Router-Edge-10080",
            "properties": {
              "priority": 130,
              "direction": "Inbound",
              "access": "Allow",
              "protocol": "Tcp",
              "sourcePortRange": "*",
              "destinationPortRange": "10080",
              "sourceAddressPrefix": "Internet",
              "destinationAddressPrefix": "*"
            }
          }
        ]
      }
    },
    {
      "type": "Microsoft.Network/routeTables",
      "apiVersion": "2023-11-01",
      "name": "[variables('routerRouteTableName')]",
      "location": "[resourceGroup().location]",
      "properties": {
        "disableBgpRoutePropagation": false,
        "routes": []
      }
    },
    {
      "type": "Microsoft.Network/virtualNetworks",
      "apiVersion": "2023-11-01",
      "name": "[parameters('vnetName')]",
      "location": "[resourceGroup().location]",
      "dependsOn": [
        "[resourceId('Microsoft.Network/networkSecurityGroups', variables('infraNsgName'))]",
        "[resourceId('Microsoft.Network/networkSecurityGroups', variables('routerNsgName'))]",
        "[resourceId('Microsoft.Network/routeTables', variables('routerRouteTableName'))]"
      ],
      "properties": {
        "addressSpace": {
          "addressPrefixes": [
            "[parameters('vnetAddressPrefix')]"
          ]
        },
        "subnets": [
          {
            "name": "[parameters('infraSubnetName')]",
            "properties": {
              "addressPrefix": "[parameters('infraSubnetPrefix')]",
              "networkSecurityGroup": {
                "id": "[resourceId('Microsoft.Network/networkSecurityGroups', variables('infraNsgName'))]"
              }
            }
          },
          {
            "name": "[parameters('routerSubnetName')]",
            "properties": {
              "addressPrefix": "[parameters('routerSubnetPrefix')]",
              "networkSecurityGroup": {
                "id": "[resourceId('Microsoft.Network/networkSecurityGroups', variables('routerNsgName'))]"
              },
              "routeTable": {
                "id": "[resourceId('Microsoft.Network/routeTables', variables('routerRouteTableName'))]"
              }
            }
          }
        ]
      }
    },
    {
      "type": "Microsoft.Network/publicIPAddresses",
      "apiVersion": "2023-11-01",
      "name": "[concat(variables('controller01VmName'), '-pip')]",
      "location": "[resourceGroup().location]",
      "sku": {
        "name": "Standard"
      },
      "properties": {
        "publicIPAllocationMethod": "Static",
        "publicIPAddressVersion": "IPv4",
        "dnsSettings": {
          "domainNameLabel": "[concat(parameters('dnsLabelPrefix'), '-c01')]"
        }
      }
    },
    {
      "type": "Microsoft.Network/networkInterfaces",
      "apiVersion": "2023-11-01",
      "name": "[concat(variables('controller01VmName'), '-nic')]",
      "location": "[resourceGroup().location]",
      "dependsOn": [
        "[resourceId('Microsoft.Network/virtualNetworks', parameters('vnetName'))]",
        "[resourceId('Microsoft.Network/publicIPAddresses', concat(variables('controller01VmName'), '-pip'))]"
      ],
      "properties": {
        "ipConfigurations": [
          {
            "name": "ipconfig1",
            "properties": {
              "privateIPAllocationMethod": "Static",
              "privateIPAddress": "[variables('controller01PrivateIp')]",
              "subnet": {
                "id": "[resourceId('Microsoft.Network/virtualNetworks/subnets', parameters('vnetName'), parameters('infraSubnetName'))]"
              },
              "publicIPAddress": {
                "id": "[resourceId('Microsoft.Network/publicIPAddresses', concat(variables('controller01VmName'), '-pip'))]"
              }
            }
          }
        ]
      }
    },
    {
      "type": "Microsoft.Compute/virtualMachines",
      "apiVersion": "2024-07-01",
      "name": "[variables('controller01VmName')]",
      "location": "[resourceGroup().location]",
      "zones": [
        "[parameters('controller01Zone')]"
      ],
      "dependsOn": [
        "[resourceId('Microsoft.Network/networkInterfaces', concat(variables('controller01VmName'), '-nic'))]"
      ],
      "properties": {
        "hardwareProfile": {
          "vmSize": "[parameters('controllerVmSize')]"
        },
        "storageProfile": {
          "imageReference": {
            "publisher": "Canonical",
            "offer": "ubuntu-24_04-lts",
            "sku": "server",
            "version": "latest"
          },
          "osDisk": {
            "createOption": "FromImage",
            "managedDisk": {
              "storageAccountType": "Premium_LRS"
            }
          }
        },
        "osProfile": {
          "computerName": "[variables('controller01VmName')]",
          "adminUsername": "[parameters('adminUsername')]",
          "adminPassword": "[parameters('adminPassword')]",
          "linuxConfiguration": {
            "disablePasswordAuthentication": false
          }
        },
        "networkProfile": {
          "networkInterfaces": [
            {
              "id": "[resourceId('Microsoft.Network/networkInterfaces', concat(variables('controller01VmName'), '-nic'))]"
            }
          ]
        },
        "diagnosticsProfile": {
          "bootDiagnostics": {
            "enabled": true
          }
        }
      }
    },
    {
      "type": "Microsoft.Compute/virtualMachines/extensions",
      "apiVersion": "2024-07-01",
      "name": "[concat(variables('controller01VmName'), '/CustomScript')]",
      "location": "[resourceGroup().location]",
      "dependsOn": [
        "[resourceId('Microsoft.Compute/virtualMachines', variables('controller01VmName'))]",
        "[resourceId('Microsoft.Compute/virtualMachines/extensions', variables('controller02VmName'), 'CustomScript')]",
        "[resourceId('Microsoft.Compute/virtualMachines/extensions', variables('controller03VmName'), 'CustomScript')]",
        "[resourceId('Microsoft.Compute/virtualMachines/extensions', variables('router01VmName'), 'CustomScript')]",
        "[resourceId('Microsoft.Compute/virtualMachines/extensions', variables('router02VmName'), 'CustomScript')]",
        "[resourceId('Microsoft.Compute/virtualMachines/extensions', variables('router03VmName'), 'CustomScript')]"
      ],
      "properties": {
        "publisher": "Microsoft.Azure.Extensions",
        "type": "CustomScript",
        "typeHandlerVersion": "2.1",
        "autoUpgradeMinorVersion": true,
        "settings": {
          "fileUris": [
            "[variables('controllerPrimaryScriptUrl')]"
          ]
        },
        "protectedSettings": {
          "commandToExecute": "[concat('bash azure-bootstrap-ziti-ha-controller-primary-v4.sh ', parameters('adminUsername'), ' ', base64(parameters('adminPassword')), ' ', parameters('zitiAdminUser'), ' ', base64(parameters('zitiAdminPassword')), ' ', parameters('deploymentPrefix'), ' ', variables('controller01VmName'), ' ', variables('controller02VmName'), ' ', variables('controller03VmName'), ' ', variables('router01VmName'), ' ', variables('router02VmName'), ' ', variables('router03VmName'), ' ', variables('controller01Fqdn'), ' ', variables('controller02Fqdn'), ' ', variables('controller03Fqdn'), ' ', variables('router01Fqdn'), ' ', variables('router02Fqdn'), ' ', variables('router03Fqdn'), ' ', parameters('runAptUpgrade'))]"
        }
      }
    },
    {
      "type": "Microsoft.Network/publicIPAddresses",
      "apiVersion": "2023-11-01",
      "name": "[concat(variables('controller02VmName'), '-pip')]",
      "location": "[resourceGroup().location]",
      "sku": {
        "name": "Standard"
      },
      "properties": {
        "publicIPAllocationMethod": "Static",
        "publicIPAddressVersion": "IPv4",
        "dnsSettings": {
          "domainNameLabel": "[concat(parameters('dnsLabelPrefix'), '-c02')]"
        }
      }
    },
    {
      "type": "Microsoft.Network/networkInterfaces",
      "apiVersion": "2023-11-01",
      "name": "[concat(variables('controller02VmName'), '-nic')]",
      "location": "[resourceGroup().location]",
      "dependsOn": [
        "[resourceId('Microsoft.Network/virtualNetworks', parameters('vnetName'))]",
        "[resourceId('Microsoft.Network/publicIPAddresses', concat(variables('controller02VmName'), '-pip'))]"
      ],
      "properties": {
        "ipConfigurations": [
          {
            "name": "ipconfig1",
            "properties": {
              "privateIPAllocationMethod": "Static",
              "privateIPAddress": "[variables('controller02PrivateIp')]",
              "subnet": {
                "id": "[resourceId('Microsoft.Network/virtualNetworks/subnets', parameters('vnetName'), parameters('infraSubnetName'))]"
              },
              "publicIPAddress": {
                "id": "[resourceId('Microsoft.Network/publicIPAddresses', concat(variables('controller02VmName'), '-pip'))]"
              }
            }
          }
        ]
      }
    },
    {
      "type": "Microsoft.Compute/virtualMachines",
      "apiVersion": "2024-07-01",
      "name": "[variables('controller02VmName')]",
      "location": "[resourceGroup().location]",
      "zones": [
        "[parameters('controller02Zone')]"
      ],
      "dependsOn": [
        "[resourceId('Microsoft.Network/networkInterfaces', concat(variables('controller02VmName'), '-nic'))]"
      ],
      "properties": {
        "hardwareProfile": {
          "vmSize": "[parameters('controllerVmSize')]"
        },
        "storageProfile": {
          "imageReference": {
            "publisher": "Canonical",
            "offer": "ubuntu-24_04-lts",
            "sku": "server",
            "version": "latest"
          },
          "osDisk": {
            "createOption": "FromImage",
            "managedDisk": {
              "storageAccountType": "Premium_LRS"
            }
          }
        },
        "osProfile": {
          "computerName": "[variables('controller02VmName')]",
          "adminUsername": "[parameters('adminUsername')]",
          "adminPassword": "[parameters('adminPassword')]",
          "linuxConfiguration": {
            "disablePasswordAuthentication": false
          }
        },
        "networkProfile": {
          "networkInterfaces": [
            {
              "id": "[resourceId('Microsoft.Network/networkInterfaces', concat(variables('controller02VmName'), '-nic'))]"
            }
          ]
        },
        "diagnosticsProfile": {
          "bootDiagnostics": {
            "enabled": true
          }
        }
      }
    },
    {
      "type": "Microsoft.Compute/virtualMachines/extensions",
      "apiVersion": "2024-07-01",
      "name": "[concat(variables('controller02VmName'), '/CustomScript')]",
      "location": "[resourceGroup().location]",
      "dependsOn": [
        "[resourceId('Microsoft.Compute/virtualMachines', variables('controller02VmName'))]"
      ],
      "properties": {
        "publisher": "Microsoft.Azure.Extensions",
        "type": "CustomScript",
        "typeHandlerVersion": "2.1",
        "autoUpgradeMinorVersion": true,
        "settings": {
          "fileUris": [
            "[variables('controllerSecondaryScriptUrl')]"
          ]
        },
        "protectedSettings": {
          "commandToExecute": "[concat('bash azure-bootstrap-ziti-ha-controller-secondary-v4.sh ', variables('controller02VmName'), ' ', variables('controller02Fqdn'), ' ', parameters('runAptUpgrade'))]"
        }
      }
    },
    {
      "type": "Microsoft.Network/publicIPAddresses",
      "apiVersion": "2023-11-01",
      "name": "[concat(variables('controller03VmName'), '-pip')]",
      "location": "[resourceGroup().location]",
      "sku": {
        "name": "Standard"
      },
      "properties": {
        "publicIPAllocationMethod": "Static",
        "publicIPAddressVersion": "IPv4",
        "dnsSettings": {
          "domainNameLabel": "[concat(parameters('dnsLabelPrefix'), '-c03')]"
        }
      }
    },
    {
      "type": "Microsoft.Network/networkInterfaces",
      "apiVersion": "2023-11-01",
      "name": "[concat(variables('controller03VmName'), '-nic')]",
      "location": "[resourceGroup().location]",
      "dependsOn": [
        "[resourceId('Microsoft.Network/virtualNetworks', parameters('vnetName'))]",
        "[resourceId('Microsoft.Network/publicIPAddresses', concat(variables('controller03VmName'), '-pip'))]"
      ],
      "properties": {
        "ipConfigurations": [
          {
            "name": "ipconfig1",
            "properties": {
              "privateIPAllocationMethod": "Static",
              "privateIPAddress": "[variables('controller03PrivateIp')]",
              "subnet": {
                "id": "[resourceId('Microsoft.Network/virtualNetworks/subnets', parameters('vnetName'), parameters('infraSubnetName'))]"
              },
              "publicIPAddress": {
                "id": "[resourceId('Microsoft.Network/publicIPAddresses', concat(variables('controller03VmName'), '-pip'))]"
              }
            }
          }
        ]
      }
    },
    {
      "type": "Microsoft.Compute/virtualMachines",
      "apiVersion": "2024-07-01",
      "name": "[variables('controller03VmName')]",
      "location": "[resourceGroup().location]",
      "zones": [
        "[parameters('controller03Zone')]"
      ],
      "dependsOn": [
        "[resourceId('Microsoft.Network/networkInterfaces', concat(variables('controller03VmName'), '-nic'))]"
      ],
      "properties": {
        "hardwareProfile": {
          "vmSize": "[parameters('controllerVmSize')]"
        },
        "storageProfile": {
          "imageReference": {
            "publisher": "Canonical",
            "offer": "ubuntu-24_04-lts",
            "sku": "server",
            "version": "latest"
          },
          "osDisk": {
            "createOption": "FromImage",
            "managedDisk": {
              "storageAccountType": "Premium_LRS"
            }
          }
        },
        "osProfile": {
          "computerName": "[variables('controller03VmName')]",
          "adminUsername": "[parameters('adminUsername')]",
          "adminPassword": "[parameters('adminPassword')]",
          "linuxConfiguration": {
            "disablePasswordAuthentication": false
          }
        },
        "networkProfile": {
          "networkInterfaces": [
            {
              "id": "[resourceId('Microsoft.Network/networkInterfaces', concat(variables('controller03VmName'), '-nic'))]"
            }
          ]
        },
        "diagnosticsProfile": {
          "bootDiagnostics": {
            "enabled": true
          }
        }
      }
    },
    {
      "type": "Microsoft.Compute/virtualMachines/extensions",
      "apiVersion": "2024-07-01",
      "name": "[concat(variables('controller03VmName'), '/CustomScript')]",
      "location": "[resourceGroup().location]",
      "dependsOn": [
        "[resourceId('Microsoft.Compute/virtualMachines', variables('controller03VmName'))]"
      ],
      "properties": {
        "publisher": "Microsoft.Azure.Extensions",
        "type": "CustomScript",
        "typeHandlerVersion": "2.1",
        "autoUpgradeMinorVersion": true,
        "settings": {
          "fileUris": [
            "[variables('controllerSecondaryScriptUrl')]"
          ]
        },
        "protectedSettings": {
          "commandToExecute": "[concat('bash azure-bootstrap-ziti-ha-controller-secondary-v4.sh ', variables('controller03VmName'), ' ', variables('controller03Fqdn'), ' ', parameters('runAptUpgrade'))]"
        }
      }
    },
    {
      "type": "Microsoft.Network/publicIPAddresses",
      "apiVersion": "2023-11-01",
      "name": "[concat(variables('router01VmName'), '-pip')]",
      "location": "[resourceGroup().location]",
      "sku": {
        "name": "Standard"
      },
      "properties": {
        "publicIPAllocationMethod": "Static",
        "publicIPAddressVersion": "IPv4",
        "dnsSettings": {
          "domainNameLabel": "[concat(parameters('dnsLabelPrefix'), '-r01')]"
        }
      }
    },
    {
      "type": "Microsoft.Network/networkInterfaces",
      "apiVersion": "2023-11-01",
      "name": "[concat(variables('router01VmName'), '-nic')]",
      "location": "[resourceGroup().location]",
      "dependsOn": [
        "[resourceId('Microsoft.Network/virtualNetworks', parameters('vnetName'))]",
        "[resourceId('Microsoft.Network/publicIPAddresses', concat(variables('router01VmName'), '-pip'))]"
      ],
      "properties": {
        "ipConfigurations": [
          {
            "name": "ipconfig1",
            "properties": {
              "privateIPAllocationMethod": "Static",
              "privateIPAddress": "[variables('router01PrivateIp')]",
              "subnet": {
                "id": "[resourceId('Microsoft.Network/virtualNetworks/subnets', parameters('vnetName'), parameters('routerSubnetName'))]"
              },
              "publicIPAddress": {
                "id": "[resourceId('Microsoft.Network/publicIPAddresses', concat(variables('router01VmName'), '-pip'))]"
              }
            }
          }
        ]
      }
    },
    {
      "type": "Microsoft.Compute/virtualMachines",
      "apiVersion": "2024-07-01",
      "name": "[variables('router01VmName')]",
      "location": "[resourceGroup().location]",
      "zones": [
        "[parameters('router01Zone')]"
      ],
      "dependsOn": [
        "[resourceId('Microsoft.Network/networkInterfaces', concat(variables('router01VmName'), '-nic'))]"
      ],
      "properties": {
        "hardwareProfile": {
          "vmSize": "[parameters('routerVmSize')]"
        },
        "storageProfile": {
          "imageReference": {
            "publisher": "Canonical",
